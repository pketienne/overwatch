#!/bin/sh
# /etc/grub.d/40_overwatch_modes — emit two custom menuentries for the
# overwatch host-mode / vm-mode reboot-based mode switching system.
#
# host-mode (default): dGPU on amdgpu, ollama can run inference, full host
#                      CPU/RAM available, no hugepages or core isolation.
# vm-mode:             dGPU on vfio-pci at boot, hugepages reserved, host
#                      CPUs 2-7 isolated, VM auto-started by overwatch-resume.
#
# Both entries boot the same kernel + initrd; only the cmdline differs.
# GRUB_DEFAULT in /etc/default/grub points at overwatch-host-mode so any
# unintended reboot returns to a working ollama box. The desktop shortcut
# (and `overwatch-mode require vm`) uses `grub-reboot overwatch-vm-mode`
# to one-shot the next boot into vm-mode; subsequent boots revert to host.
#
# Managed by Chef (overwatch cookbook). Do not edit directly.

set -e

# --- Cmdline params (rendered by Chef from cookbook attributes) ---

CMDLINE_COMMON="<%= @cmdline_common %>"
CMDLINE_HOST_MODE="<%= @cmdline_host_mode %>"
CMDLINE_VM_MODE="<%= @cmdline_vm_mode %>"

# --- Discover boot artefacts ---

# Latest installed kernel + matching initrd. We sort by version (sort -V)
# rather than mtime so a freshly installed older kernel doesn't win.
linux_image=$(ls /boot/vmlinuz-* 2>/dev/null | sort -V | tail -1)
[ -z "$linux_image" ] && exit 0
kver=${linux_image#/boot/vmlinuz-}
initrd_image="/boot/initrd.img-${kver}"
[ ! -f "$initrd_image" ] && exit 0

# Root filesystem UUID — use findmnt (reliable on all live systems).
root_uuid=$(findmnt -no UUID /)
[ -z "$root_uuid" ] && exit 0

# Optional GRUB_CMDLINE_LINUX (passed in addition to GRUB_CMDLINE_LINUX_DEFAULT
# on every Ubuntu install). Inherited verbatim so we don't lose distro defaults.
if [ -r /etc/default/grub ]; then
    # shellcheck disable=SC1091
    . /etc/default/grub
fi
distro_cmdline="${GRUB_CMDLINE_LINUX:-} ${GRUB_CMDLINE_LINUX_DEFAULT:-}"
# Strip any pre-existing overwatch.mode=* tokens so our entries always win.
distro_cmdline=$(echo "$distro_cmdline" | sed -E 's/(^|[[:space:]])overwatch\.mode=[^[:space:]]*//g' | xargs)

# Early initrd images (e.g., GRUB_EARLY_INITRD_LINUX_CUSTOM=ivrs-override.img,
# which is required on this AMD platform to patch the IVRS table so vfio-pci
# can claim the dGPU — without it, the firmware-marked "1:1 IOMMU mapping"
# requirement makes vfio_iommu_type1 reject container setup at QEMU start).
# Mirrors what /etc/grub.d/10_linux does for the regular Ubuntu menuentry.
early_initrds=""
if [ -n "${GRUB_EARLY_INITRD_LINUX_CUSTOM:-}" ]; then
    for img in $GRUB_EARLY_INITRD_LINUX_CUSTOM; do
        if [ -r "/boot/$img" ]; then
            early_initrds="$early_initrds /boot/$img"
        fi
    done
fi
# Trim leading whitespace
early_initrds=$(echo "$early_initrds" | xargs)

# --- Emit menuentries ---

# Build the initrd line: early initrds first (if any), then the regular initrd.
if [ -n "$early_initrds" ]; then
    initrd_line="initrd $early_initrds /boot/initrd.img-${kver}"
else
    initrd_line="initrd /boot/initrd.img-${kver}"
fi

cat <<EOF
menuentry 'Overwatch (host-mode) — ollama, full host' --id overwatch-host-mode {
    recordfail
    load_video
    gfxmode \$linux_gfx_mode
    insmod gzio
    insmod part_gpt
    insmod ext2
    search --no-floppy --fs-uuid --set=root ${root_uuid}
    echo 'Loading Linux ${kver} (overwatch host-mode) ...'
    linux /boot/vmlinuz-${kver} root=UUID=${root_uuid} ro ${distro_cmdline} ${CMDLINE_COMMON} ${CMDLINE_HOST_MODE}
    echo 'Loading initial ramdisk ...'
    ${initrd_line}
}

menuentry 'Overwatch (vm-mode) — GPU passthrough' --id overwatch-vm-mode {
    recordfail
    load_video
    gfxmode \$linux_gfx_mode
    insmod gzio
    insmod part_gpt
    insmod ext2
    search --no-floppy --fs-uuid --set=root ${root_uuid}
    echo 'Loading Linux ${kver} (overwatch vm-mode) ...'
    linux /boot/vmlinuz-${kver} root=UUID=${root_uuid} ro ${distro_cmdline} ${CMDLINE_COMMON} ${CMDLINE_VM_MODE}
    echo 'Loading initial ramdisk ...'
    ${initrd_line}
}
EOF
