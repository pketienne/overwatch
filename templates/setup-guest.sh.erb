# ============================================================

ensure_transition_throttle() {
    log "=== Transition throttle + AMD driver monitor ==="
    guest_python << 'PYEOF'
import os

# Ensure C:\Scripts exists
run_ps(r"New-Item -ItemType Directory -Path 'C:\Scripts' -Force | Out-Null")

# --- Deploy files ---
# transition-throttle.ps1            - the throttle engine (registry-driven)
# throttle-registry-init.ps1         - one-shot HKCU seeder run after deploy
# transition-throttle-tray.ps1       - throttle controller tray (status + toggles)
# transition-throttle-launcher.vbs   - silent launcher for the engine (legacy)
# transition-throttle-tray-launcher.vbs - silent launcher for the throttle tray
# amd-driver-monitor-tray.ps1        - independent AMD ULPS health watcher
# amd-driver-monitor-launcher.vbs    - silent launcher for the AMD monitor tray
host_dir = "/usr/local/share/overwatch"
files = [
    "transition-throttle.ps1",
    "throttle-registry-init.ps1",
    "transition-throttle-tray.ps1",
    "transition-throttle-launcher.vbs",
    "transition-throttle-tray-launcher.vbs",
    "amd-driver-monitor-tray.ps1",
    "amd-driver-monitor-launcher.vbs",
]

any_written = False
for fname in files:
    host_path = os.path.join(host_dir, fname)
    guest_path = rf"C:\Scripts\{fname}"

    if not os.path.exists(host_path):
        log(f"ERROR: {host_path} not found on host — deploy it first")
        sys.exit(1)

    with open(host_path, "rb") as f:
        content = f.read()

    # Check if guest file matches (skip if identical)
    existing = run_ps(
        f"if(Test-Path '{guest_path}'){{ 'EXISTS' }} else {{ 'MISSING' }}"
    )
    if "EXISTS" in (existing or ""):
        # Compare content via hash
        import hashlib
        local_hash = hashlib.sha256(content).hexdigest()[:16]
        remote_hash = run_ps(
            f"(Get-FileHash '{guest_path}' -Algorithm SHA256).Hash.Substring(0,16).ToLower()"
        )
        if remote_hash and local_hash == remote_hash.strip().lower():
            log(f"{fname}: up to date")
            continue

    if DRY_RUN:
        log(f"[dry-run] Would write {guest_path}")
        continue

    if guest_file_write(guest_path, content):
        log(f"Wrote {fname}")
        any_written = True
    else:
        log(f"ERROR: Failed to write {fname}")
        sys.exit(1)

# --- Run throttle-registry-init.ps1 to seed HKCU defaults ---
# Idempotent: only writes values that are missing, never overwrites
# user-set values from the tray. Run as the interactive user via a
# one-shot scheduled task so the writes land in the user's HKCU hive.
if not DRY_RUN:
    init_task_name = f"OverwatchThrottleRegistryInit_{os.getpid()}"
    run_ps(
        f"$action = New-ScheduledTaskAction -Execute 'powershell.exe' "
        f"-Argument '-NoProfile -WindowStyle Hidden -ExecutionPolicy Bypass -File C:\\Scripts\\throttle-registry-init.ps1'; "
        f"$principal = New-ScheduledTaskPrincipal -UserId '{WINDOWS_USER}' -LogonType Interactive -RunLevel Highest; "
        f"$task = New-ScheduledTask -Action $action -Principal $principal; "
        f"Register-ScheduledTask -TaskName '{init_task_name}' -InputObject $task -Force | Out-Null; "
        f"Start-ScheduledTask -TaskName '{init_task_name}'; "
        f"Start-Sleep -Seconds 2; "
        f"Unregister-ScheduledTask -TaskName '{init_task_name}' -Confirm:$false -EA SilentlyContinue"
    )
    log("Ran throttle-registry-init.ps1 (HKCU seeded with cookbook defaults if missing)")
else:
    log("[dry-run] Would run throttle-registry-init.ps1 in user session")

# --- Helper: register a scheduled task that runs as the interactive user ---
def ensure_logon_task(name, exec, args):
    state = run_ps(
        f"$t = Get-ScheduledTask -TaskName '{name}' -EA SilentlyContinue; "
        f"if($t){{ $t.State }} else {{ 'MISSING' }}"
    )
    if "MISSING" not in (state or "MISSING"):
        log(f"Task '{name}': already configured (state={state})")
        return
    if DRY_RUN:
        log(f"[dry-run] Would create '{name}' scheduled task")
        return
    run_ps(
        f"$action = New-ScheduledTaskAction -Execute '{exec}' -Argument '{args}'; "
        f"$trigger = New-ScheduledTaskTrigger -AtLogon -User '{WINDOWS_USER}'; "
        f"$principal = New-ScheduledTaskPrincipal -UserId '{WINDOWS_USER}' -LogonType Interactive -RunLevel Highest; "
        f"$settings = New-ScheduledTaskSettingsSet -ExecutionTimeLimit ([TimeSpan]::Zero) "
        f"-RestartCount 3 -RestartInterval ([TimeSpan]::FromMinutes(1)) -AllowStartIfOnBatteries; "
        f"Unregister-ScheduledTask -TaskName '{name}' -Confirm:$false -EA SilentlyContinue; "
        f"Register-ScheduledTask -TaskName '{name}' -Action $action "
        f"-Trigger $trigger -Principal $principal -Settings $settings"
    )
    log(f"Created '{name}' scheduled task (AtLogon)")

# --- Three scheduled tasks ---
ensure_logon_task(
    'OW2 Transition Throttle',
    'powershell.exe',
    '-NoProfile -WindowStyle Hidden -ExecutionPolicy Bypass -File C:\\Scripts\\transition-throttle.ps1'
)
ensure_logon_task(
    'OW2 Transition Throttle Tray',
    'wscript.exe',
    'C:\\Scripts\\transition-throttle-tray-launcher.vbs'
)
ensure_logon_task(
    'AMD Driver Monitor',
    'wscript.exe',
    'C:\\Scripts\\amd-driver-monitor-launcher.vbs'
)
PYEOF
}

