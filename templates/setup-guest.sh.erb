PYEOF
}

# ============================================================
# Verify all guest settings (dry-run of do_all)
# ============================================================

verify_guest() {
    DRY_RUN=true
    do_all
}

# ============================================================
# Main dispatch
# ============================================================

do_all() {
    ensure_power_settings
    ensure_hda_audio
    ensure_defender_exclusions
    ensure_telemetry_disabled
    ensure_display_config
    ensure_onedrive_removed
    ensure_suggestions_disabled
    ensure_shutdown_signal
    ensure_transition_throttle
    ensure_synapse_delayed
    ensure_lhm_drivers_removed
    log "=== Guest configuration complete ==="
}

case "$CMD" in
    all|power|hda-audio|defender|telemetry|display|onedrive|suggestions|shutdown|transition|synapse|lhm-drivers|boot-timing)
        ensure_guest_agent
        ;;&
    all)          do_all ;;
    power)        ensure_power_settings ;;
    hda-audio)    ensure_hda_audio ;;
    defender)     ensure_defender_exclusions ;;
    telemetry)    ensure_telemetry_disabled ;;
    display)      ensure_display_config ;;
    onedrive)     ensure_onedrive_removed ;;
    suggestions)  ensure_suggestions_disabled ;;
    shutdown)     ensure_shutdown_signal ;;
    transition)   ensure_transition_throttle ;;
    synapse)      ensure_synapse_delayed ;;
    lhm-drivers)  ensure_lhm_drivers_removed ;;
    boot-timing)  show_boot_timing ;;
    verify)       ensure_guest_agent && verify_guest ;;
    *)
        log "ERROR: Unknown subcommand '$CMD'"
        exit 1
        ;;
esac
