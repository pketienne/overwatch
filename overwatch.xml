<domain type='kvm' xmlns:qemu='http://libvirt.org/schemas/domain/qemu/1.0'>
  <name>overwatch</name>
  <uuid>ee9489dc-57fe-4405-ace6-73dcf9074201</uuid>
  <memory unit='GiB'>88</memory>
  <currentMemory unit='GiB'>88</currentMemory>
  <vcpu placement='static'>6</vcpu>
  <cpu mode='host-passthrough' check='none' migratable='off'>
    <topology sockets='1' dies='1' cores='6' threads='1'/>
    <feature policy='require' name='topoext'/>
  </cpu>

  <os firmware='efi'>
    <type arch='x86_64' machine='pc-q35-8.2'>hvm</type>
    <firmware>
      <feature enabled='yes' name='enrolled-keys'/>
      <feature enabled='yes' name='secure-boot'/>
    </firmware>
    <boot dev='hd'/>
  </os>

  <features>
    <acpi/>
    <apic/>
    <hyperv mode='custom'>
      <relaxed state='on'/>
      <vapic state='on'/>
      <spinlocks state='on' retries='8191'/>
      <vpindex state='on'/>
      <runtime state='on'/>
      <synic state='on'/>
      <stimer state='on'/>
      <frequencies state='on'/>
      <vendor_id state='on' value='AuthenticAMD'/>
    </hyperv>
    <kvm>
      <hidden state='on'/>
    </kvm>
    <vmport state='off'/>
    <ioapic driver='kvm'/>
  </features>

  <clock offset='localtime'>
    <timer name='rtc' tickpolicy='catchup'/>
    <timer name='pit' tickpolicy='delay'/>
    <timer name='hpet' present='no'/>
    <timer name='hypervclock' present='yes'/>
  </clock>

  <on_poweroff>destroy</on_poweroff>
  <on_reboot>restart</on_reboot>
  <on_crash>destroy</on_crash>

  <sysinfo type='smbios'>
    <bios>
      <entry name='vendor'>American Megatrends International, LLC.</entry>
      <entry name='version'>1.A80</entry>
      <entry name='date'>01/08/2026</entry>
    </bios>
    <system>
      <entry name='manufacturer'>Micro-Star International Co., Ltd.</entry>
      <entry name='product'>MS-7E49</entry>
      <entry name='version'>1.0</entry>
      <entry name='serial'>To be filled by O.E.M.</entry>
    </system>
    <baseBoard>
      <entry name='manufacturer'>Micro-Star International Co., Ltd.</entry>
      <entry name='product'>MPG X870E CARBON WIFI (MS-7E49)</entry>
      <entry name='version'>1.0</entry>
      <entry name='serial'>XXXXXXXXXX</entry>
    </baseBoard>
  </sysinfo>
  <smbios mode='sysinfo'/>

  <devices>
    <!-- VirtIO SCSI controller (looks like real SCSI, avoids "Red Hat virtio" fingerprint) -->
    <controller type='scsi' model='virtio-scsi'/>

    <!-- Disk: Windows -->
    <disk type='file' device='disk'>
      <driver name='qemu' type='qcow2' discard='unmap'/>
      <source file='/var/lib/libvirt/images/overwatch.qcow2'/>
      <serial>S6XWNG0R401283</serial>
      <target dev='sda' bus='scsi'/>
    </disk>


    <!-- Disk: Game (Overwatch 2) -->
    <disk type='file' device='disk'>
      <driver name='qemu' type='qcow2' discard='unmap'/>
      <source file='/var/lib/libvirt/images/overwatch-app.qcow2'/>
      <serial>S6XWNG0R401297</serial>
      <target dev='sdb' bus='scsi'/>
    </disk>

    <!-- GPU passthrough: VGA -->
    <hostdev mode='subsystem' type='pci' managed='yes'>
      <source>
        <address domain='0x0000' bus='0x03' slot='0x00' function='0x0'/>
      </source>
      <rom bar='off' file='/usr/share/qemu/gpu-rom.bin'/>
    </hostdev>

    <!-- GPU passthrough: Audio -->
    <hostdev mode='subsystem' type='pci' managed='yes'>
      <source>
        <address domain='0x0000' bus='0x03' slot='0x00' function='0x1'/>
      </source>
    </hostdev>

    <!-- Network: default NAT, Realtek OUI to avoid QEMU 52:54:00 fingerprint -->
    <interface type='network'>
      <source network='default'/>
      <mac address='aa:bb:cc:dd:ee:ff'/>
      <model type='virtio'/>
    </interface>

    <!-- Second USB controller (default xHCI only has 4 ports) -->
    <controller type='usb' model='qemu-xhci'/>

    <!-- USB passthrough: Kinesis Advantage2 keyboard -->
    <hostdev mode='subsystem' type='usb' managed='yes'>
      <source>
        <vendor id='0x29ea'/>
        <product id='0x0102'/>
      </source>
    </hostdev>

    <!-- USB passthrough: Razer Naga V2 Pro mouse -->
    <hostdev mode='subsystem' type='usb' managed='yes'>
      <source>
        <vendor id='0x1532'/>
        <product id='0x00a7'/>
      </source>
    </hostdev>

    <!-- Razer Tartarus V2 keypad: NOT here — attached by overwatch.sh after
         Synapse is running so profiles apply on hot-plug (1532:022b) -->

    <!-- USB passthrough: Razer Strider Chroma mousepad -->
    <hostdev mode='subsystem' type='usb' managed='yes'>
      <source>
        <vendor id='0x1532'/>
        <product id='0x0c05'/>
      </source>
    </hostdev>

    <!-- SteelSeries Arctis Pro Wireless: 1038:1290 is intermittent (not always
         enumerated), removed to prevent VM start failure. 1038:1294 also removed
         since both devices are part of the same headset. -->


    <!-- QEMU guest agent channel -->
    <channel type='unix'>
      <target type='virtio' name='org.qemu.guest_agent.0'/>
    </channel>


    <!-- Console -->
    <serial type='pty'>
      <target port='0'/>
    </serial>
    <console type='pty'>
      <target type='serial' port='0'/>
    </console>
  </devices>

  <qemu:commandline>
    <!-- SMBIOS Type 0: BIOS -->
    <qemu:arg value='-smbios'/>
    <qemu:arg value='type=0,vendor=American Megatrends International,, LLC.,version=1.A80,date=01/08/2026'/>
    <!-- SMBIOS Type 1: System -->
    <qemu:arg value='-smbios'/>
    <qemu:arg value='type=1,manufacturer=Micro-Star International Co.,, Ltd.,product=MS-7E49,version=1.0,serial=To be filled by O.E.M.,family=Default string'/>
    <!-- SMBIOS Type 2: Baseboard -->
    <qemu:arg value='-smbios'/>
    <qemu:arg value='type=2,manufacturer=Micro-Star International Co.,, Ltd.,product=MPG X870E CARBON WIFI (MS-7E49),version=1.0,serial=XXXXXXXXXX'/>
    <!-- SCSI disk vendor/product (replaces "QEMU QEMU HARDDISK") -->
    <qemu:arg value='-global'/>
    <qemu:arg value='scsi-hd.vendor=Samsung'/>
    <qemu:arg value='-global'/>
    <qemu:arg value='scsi-hd.product=SSD 870 EVO 1TB'/>
  </qemu:commandline>
</domain>
