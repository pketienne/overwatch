# transition-throttle.ps1 — OW2 throttle control (registry-driven, stateless)
#
# Manages OW2's CPU affinity to mitigate VFIO TDR bursts during loading
# transitions. Runtime configuration is read from the Windows registry,
# allowing the system tray icon to flip mode without restarting this
# script.
#
# Registry contract — HKCU:\Software\Overwatch\TransitionThrottle
#   Enabled  REG_DWORD  0 = no-op (script idle, OW2 left alone)
#                       1 = active (apply throttle decisions per Mode below)
#   Mode     REG_SZ     'manual' = hotkey-only toggle (Pause/Break)
#                       'auto'   = hotkey + GPU loading-screen detection
#
# State model: NONE. The script observes OW2's actual processor affinity
# every iteration. Persistent memory across iterations is a single
# timestamp ($lastLowGpu) used for hysteresis in auto mode. The OW2
# process's affinity IS the de facto state — if any other tool (or the
# tray's "Force" buttons) flips affinity directly, the script adapts
# without confusion.
#
# Wakeups: change notifications via RegNotifyChangeKeyValue (kernel
# event, no polling) interrupt the active loop's sleep so registry
# changes apply within milliseconds.
#
# Audio cues: two beeps = full mode, one beep = throttled mode.
#
# Deploy: C:\Scripts\transition-throttle.ps1
# Task Scheduler: AtLogon, Interactive, Highest, indefinite
#
# Setup (run once from host via guest agent or on guest as admin):
#   $action = New-ScheduledTaskAction -Execute 'powershell.exe' `
#     -Argument '-NoProfile -WindowStyle Hidden -ExecutionPolicy Bypass -File C:\Scripts\transition-throttle.ps1'
#   $trigger = New-ScheduledTaskTrigger -AtLogon -User '<%= @windows_user %>'
#   $principal = New-ScheduledTaskPrincipal -UserId '<%= @windows_user %>' -LogonType Interactive -RunLevel Highest
#   $settings = New-ScheduledTaskSettingsSet -ExecutionTimeLimit ([TimeSpan]::Zero) `
#     -RestartCount 3 -RestartInterval ([TimeSpan]::FromMinutes(1)) -AllowStartIfOnBatteries
#   Register-ScheduledTask -TaskName 'OW2 Transition Throttle' -Action $action `
#     -Trigger $trigger -Principal $principal -Settings $settings

# --- Hide console window immediately ---
Add-Type -Name Window -Namespace Console -MemberDefinition '
[DllImport("Kernel32.dll")]
public static extern IntPtr GetConsoleWindow();
[DllImport("user32.dll")]
public static extern bool ShowWindow(IntPtr hWnd, Int32 nCmdShow);
'
$consolePtr = [Console.Window]::GetConsoleWindow()
[void][Console.Window]::ShowWindow($consolePtr, 0)

# --- Hotkey P/Invoke ---
Add-Type -TypeDefinition 'using System.Runtime.InteropServices;
public class User32 {
    [DllImport("user32.dll")] public static extern short GetAsyncKeyState(int vKey);
}'
$VK_PAUSE = 0x13

function Test-HotkeyPressed {
    ([User32]::GetAsyncKeyState($VK_PAUSE) -band 0x0001) -ne 0
}

# --- Registry change notification (P/Invoke) ---
# Opens HKCU:\Software\Overwatch\TransitionThrottle and registers an
# async kernel event that fires when ANY value in the key changes.
# The active loop's WaitOne() returns immediately on signal, so registry
# updates from the tray icon are applied with sub-millisecond latency.
Add-Type -TypeDefinition @"
using System;
using System.Runtime.InteropServices;
using Microsoft.Win32.SafeHandles;
public class Reg {
    public const int KEY_NOTIFY     = 0x0010;
    public const int KEY_QUERY_VALUE = 0x0001;
    public const uint REG_NOTIFY_CHANGE_LAST_SET = 0x00000004;
    public const long HKEY_CURRENT_USER = unchecked((long)0x80000001L);

    [DllImport("Advapi32.dll", CharSet = CharSet.Unicode)]
    public static extern int RegOpenKeyExW(IntPtr hKey, string subKey, uint options, int samDesired, out IntPtr phkResult);

    [DllImport("Advapi32.dll")]
    public static extern int RegNotifyChangeKeyValue(IntPtr hKey, bool watchSubtree, uint dwNotifyFilter, IntPtr hEvent, bool fAsynchronous);

    [DllImport("Advapi32.dll")]
    public static extern int RegCloseKey(IntPtr hKey);

    [DllImport("Kernel32.dll", CharSet = CharSet.Unicode)]
    public static extern IntPtr CreateEventW(IntPtr lpEventAttributes, bool bManualReset, bool bInitialState, string lpName);

    [DllImport("Kernel32.dll")]
    public static extern bool CloseHandle(IntPtr hObject);
}
"@

# --- Audio cues ---
Add-Type -ReferencedAssemblies System.dll -TypeDefinition '
using System;
using System.IO;
using System.Media;
public static class TonePlayer {
    public static byte[] GenerateWav(int freq, int durationMs) {
        int sampleRate = 44100;
        int samples = sampleRate * durationMs / 1000;
        int dataLen = samples * 2;
        var ms = new MemoryStream(44 + dataLen);
        var bw = new BinaryWriter(ms);
        bw.Write(new byte[]{0x52,0x49,0x46,0x46}); // RIFF
        bw.Write(36 + dataLen);
        bw.Write(new byte[]{0x57,0x41,0x56,0x45,0x66,0x6D,0x74,0x20}); // WAVEfmt
        bw.Write(16); bw.Write((short)1); bw.Write((short)1);
        bw.Write(sampleRate); bw.Write(sampleRate * 2);
        bw.Write((short)2); bw.Write((short)16);
        bw.Write(new byte[]{0x64,0x61,0x74,0x61}); // data
        bw.Write(dataLen);
        for (int i = 0; i < samples; i++) {
            short val = (short)(16000 * Math.Sin(2 * Math.PI * freq * i / sampleRate));
            bw.Write(val);
        }
        bw.Flush();
        return ms.ToArray();
    }
    public static void PlayAsync(byte[] wav) {
        try {
            var ms = new MemoryStream(wav);
            var player = new SoundPlayer(ms);
            player.Play(); // async, non-blocking
        } catch {}
    }
}'

$WAV_THROTTLE = [TonePlayer]::GenerateWav(600, 150)
$WAV_FULL_1   = [TonePlayer]::GenerateWav(800, 100)
$WAV_FULL_2   = [TonePlayer]::GenerateWav(1000, 100)

function Play-ThrottledCue {
    try { [TonePlayer]::PlayAsync($WAV_THROTTLE) } catch {}
}

function Play-FullCue {
    try {
        [TonePlayer]::PlayAsync($WAV_FULL_1)
        Start-Sleep -Milliseconds 200
        [TonePlayer]::PlayAsync($WAV_FULL_2)
    } catch {}
}

# --- Configuration ---
$REG_PATH          = 'HKCU:\Software\Overwatch\TransitionThrottle'
$REG_SUBKEY        = 'Software\Overwatch\TransitionThrottle'  # without HKCU prefix for P/Invoke
$POLL_IDLE_MS      = 2000    # Poll interval when OW2 not running
$POLL_ACTIVE_MS    = 500     # Active loop wait (interrupted by registry event)
$GPU_LOW           = 15      # Below this = loading screen (auto mode)
$LOADING_HOLD_MS   = 1000    # GPU must stay below GPU_LOW for this long before auto-throttle
$FULL_AFFINITY     = 0x3F    # All 6 vCPUs (bits 0-5)
$THROTTLE_AFFINITY = 0x3     # vCPUs 0-1 only
$HOST_IP           = '<%= @host_ip %>'
$HOST_PORT         = <%= @transition_signal_port %>

# --- Single-instance mutex ---
$mtx = New-Object System.Threading.Mutex($false, 'Global\TransitionThrottle')
if (-not $mtx.WaitOne(0)) {
    exit 0
}

# --- UDP sender ---
$udp = New-Object System.Net.Sockets.UdpClient
$endpoint = New-Object System.Net.IPEndPoint([System.Net.IPAddress]::Parse($HOST_IP), $HOST_PORT)

function Send-Log($msg) {
    try {
        $bytes = [System.Text.Encoding]::UTF8.GetBytes("TRANSITION $msg")
        $udp.Send($bytes, $bytes.Length, $endpoint) | Out-Null
    } catch {}
}

# --- Registry state read ---
function Get-ThrottleState {
    $s = Get-ItemProperty -Path $REG_PATH -ErrorAction SilentlyContinue
    if (-not $s) {
        # Key missing — treat as enabled+manual default
        return @{ Enabled = $true; Mode = 'manual' }
    }
    @{
        Enabled = ([int]($s.Enabled) -ne 0)
        Mode    = if ($s.Mode) { $s.Mode } else { 'manual' }
    }
}

# --- Registry change notification setup ---
function Open-RegNotifyHandle {
    $hKey = [IntPtr]::Zero
    $rc = [Reg]::RegOpenKeyExW([IntPtr]([Reg]::HKEY_CURRENT_USER), $REG_SUBKEY, 0, ([Reg]::KEY_NOTIFY -bor [Reg]::KEY_QUERY_VALUE), [ref]$hKey)
    if ($rc -ne 0) {
        Send-Log "WARN: RegOpenKeyExW rc=$rc — change notifications unavailable"
        return $null
    }
    $hKey
}

function Register-RegChangeNotification($hKey, $hEvent) {
    $rc = [Reg]::RegNotifyChangeKeyValue($hKey, $false, [Reg]::REG_NOTIFY_CHANGE_LAST_SET, $hEvent, $true)
    if ($rc -ne 0) {
        Send-Log "WARN: RegNotifyChangeKeyValue rc=$rc"
    }
}

# --- GPU counter reader (used in auto mode only) ---
function Get-OW2GpuUtil($procId) {
    try {
        $samples = (Get-Counter "\GPU Engine(pid_${procId}_*engtype_3D)\Utilization Percentage" -ErrorAction Stop).CounterSamples
        $max = ($samples | Measure-Object -Property CookedValue -Maximum).Maximum
        [math]::Round($max, 1)
    } catch {
        -1
    }
}

# --- Throttle/restore (idempotent — only act if affinity actually differs) ---
function Set-Throttle($proc) {
    try {
        if ([int]$proc.ProcessorAffinity -ne $THROTTLE_AFFINITY) {
            $proc.ProcessorAffinity = [IntPtr]$THROTTLE_AFFINITY
            $proc.PriorityClass = [System.Diagnostics.ProcessPriorityClass]::BelowNormal
            return $true
        }
    } catch {}
    $false
}

function Set-Restore($proc) {
    try {
        if ([int]$proc.ProcessorAffinity -ne $FULL_AFFINITY) {
            $proc.ProcessorAffinity = [IntPtr]$FULL_AFFINITY
            $proc.PriorityClass = [System.Diagnostics.ProcessPriorityClass]::Normal
            return $true
        }
    } catch {}
    $false
}

# --- Main loop ---
$ErrorActionPreference = 'Continue'
$lastLowGpu = $null

# Open registry handle for change notifications. Falls back to pure
# polling on RegOpenKeyEx failure (RegNotifyChangeKeyValue is best-effort).
$hRegKey = Open-RegNotifyHandle
$hEvent  = [Reg]::CreateEventW([IntPtr]::Zero, $true, $false, $null)
$waitHandle = if ($hEvent -ne [IntPtr]::Zero) {
    $h = New-Object Microsoft.Win32.SafeHandles.SafeWaitHandle($hEvent, $true)
    $w = New-Object System.Threading.ManualResetEvent($false)
    $w.SafeWaitHandle = $h
    $w
} else { $null }

if ($hRegKey -and $hEvent -ne [IntPtr]::Zero) {
    Register-RegChangeNotification $hRegKey $hEvent
}

try {
    Send-Log 'started'

    while ($true) {
        # IDLE: wait for OW2
        $ow2 = $null
        while (-not $ow2) {
            $ow2 = Get-Process -Name 'Overwatch' -ErrorAction SilentlyContinue | Select-Object -First 1
            if (-not $ow2) {
                Start-Sleep -Milliseconds $POLL_IDLE_MS
            }
        }

        $ow2pid = $ow2.Id
        Send-Log "ow2_detected pid=$ow2pid"

        # Apply initial throttle if currently enabled
        $state = Get-ThrottleState
        if ($state.Enabled) {
            if (Set-Throttle $ow2) {
                Play-ThrottledCue
                Send-Log "throttle_on startup mode=$($state.Mode)"
            }
        }

        try {
            # Active loop while OW2 is running
            while ($true) {
                try { $ow2.Refresh(); if ($ow2.HasExited) { break } } catch { Send-Log "ERROR refresh: $_"; break }

                $state = Get-ThrottleState

                # If disabled mid-session: restore to full and idle
                if (-not $state.Enabled) {
                    if (Set-Restore $ow2) {
                        Play-FullCue
                        Send-Log 'restored disabled'
                    }
                    if ($waitHandle) {
                        $signaled = $waitHandle.WaitOne($POLL_ACTIVE_MS)
                        if ($signaled) {
                            $waitHandle.Reset() | Out-Null
                            Register-RegChangeNotification $hRegKey $hEvent
                        }
                    } else {
                        Start-Sleep -Milliseconds $POLL_ACTIVE_MS
                    }
                    continue
                }

                $isThrottled = ([int]$ow2.ProcessorAffinity -eq $THROTTLE_AFFINITY)

                # --- Pause/Break hotkey toggle (works in both modes) ---
                if (Test-HotkeyPressed) {
                    if ($isThrottled) {
                        Set-Restore $ow2 | Out-Null
                        Send-Log 'hotkey_full'
                        Play-FullCue
                        $lastLowGpu = $null
                    } else {
                        Set-Throttle $ow2 | Out-Null
                        Send-Log 'hotkey_throttle'
                        Play-ThrottledCue
                    }
                    if ($waitHandle) {
                        $signaled = $waitHandle.WaitOne($POLL_ACTIVE_MS)
                        if ($signaled) {
                            $waitHandle.Reset() | Out-Null
                            Register-RegChangeNotification $hRegKey $hEvent
                        }
                    } else {
                        Start-Sleep -Milliseconds $POLL_ACTIVE_MS
                    }
                    continue
                }

                # --- Auto mode: GPU loading-screen detection ---
                # Triggers throttle when GPU is below threshold for HOLD_MS.
                # Never auto-unthrottles — user must hotkey/tray to exit.
                if ($state.Mode -eq 'auto' -and -not $isThrottled) {
                    $gpu = Get-OW2GpuUtil $ow2pid
                    if ($gpu -ge 0 -and $gpu -lt $GPU_LOW) {
                        if ($null -eq $lastLowGpu) { $lastLowGpu = [DateTime]::UtcNow }
                        if (([DateTime]::UtcNow - $lastLowGpu).TotalMilliseconds -ge $LOADING_HOLD_MS) {
                            Set-Throttle $ow2 | Out-Null
                            Send-Log "auto_throttle gpu=$gpu"
                            Play-ThrottledCue
                            $lastLowGpu = $null
                        }
                    } else {
                        $lastLowGpu = $null
                    }
                }

                # Wait for either time tick OR registry change
                if ($waitHandle) {
                    $signaled = $waitHandle.WaitOne($POLL_ACTIVE_MS)
                    if ($signaled) {
                        $waitHandle.Reset() | Out-Null
                        Register-RegChangeNotification $hRegKey $hEvent
                        Send-Log "registry_change_detected"
                    }
                } else {
                    Start-Sleep -Milliseconds $POLL_ACTIVE_MS
                }
            }
        } finally {
            # Always restore if OW2 exits while throttled
            if ($ow2 -and -not $ow2.HasExited -and ([int]$ow2.ProcessorAffinity -eq $THROTTLE_AFFINITY)) {
                Set-Restore $ow2 | Out-Null
            }
        }

        $lastLowGpu = $null
        Send-Log "ow2_exited pid=$ow2pid"
    }
} catch {
    Send-Log "FATAL: $_"
} finally {
    Send-Log 'stopped'
    if ($hRegKey) { [Reg]::RegCloseKey($hRegKey) | Out-Null }
    if ($hEvent -ne [IntPtr]::Zero) { [Reg]::CloseHandle($hEvent) | Out-Null }
    $udp.Close()
    $mtx.ReleaseMutex()
    $mtx.Dispose()
}
